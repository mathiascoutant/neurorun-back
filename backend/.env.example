PORT=8080
# Ex. LISTEN_HOST=127.0.0.1 si tu passes le binaire en network_mode host derrière nginx.
# LISTEN_HOST=
# Comme sur un autre projet Atlas : URI seule + MONGODB_DB. Tu peux ajouter ?appName=neurorun
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.net/runapp?retryWrites=true&w=majority
MONGODB_DB=runapp
# Secours uniquement si problème TLS / IPv6 : MONGODB_FORCE_IPV4=1 et/ou MONGODB_TLS12_ONLY=1

JWT_SECRET=change-me-min-16-chars-secret

# Email (minuscules) qui reçoit automatiquement le rôle admin à l’inscription.
# ADMIN_EMAIL=toi@example.com

# Optionnel au démarrage : l’API tourne sans, mais la liaison Strava / le chat activités nécessitent les 3 lignes.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8080/api/strava/callback

# Une seule URL conseillée (ex. prod). Si tu mets plusieurs URLs séparées par des virgules, le backend
# garde pour Strava la première origine https hors localhost (évite redirects OAuth invalides).
FRONTEND_URL=http://localhost:3000
# Plusieurs origines : plutôt CORS_ALLOWED_ORIGINS. FRONTEND_URL est aussi fusionné dans CORS ; le backend ajoute
# CORS_ALLOWED_ORIGINS=https://ton-user.github.io

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
