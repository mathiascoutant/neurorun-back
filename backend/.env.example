PORT=8080
# Ex. LISTEN_HOST=127.0.0.1 si tu passes le binaire en network_mode host derrière nginx.
# LISTEN_HOST=
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.net/runapp?retryWrites=true&w=majority
MONGODB_DB=runapp
# Défaut : IPv4 uniquement vers Mongo (évite « tls: internal error » si l’IPv6 du VPS/Docker est mal routé). Désactiver : MONGODB_FORCE_IPV4=0

JWT_SECRET=change-me-min-16-chars-secret

# Optionnel au démarrage : l’API tourne sans, mais la liaison Strava / le chat activités nécessitent les 3 lignes.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8080/api/strava/callback

FRONTEND_URL=http://localhost:3000
# Plusieurs origines séparées par des virgules. FRONTEND_URL est fusionné ; le backend ajoute aussi
# http://localhost:3000 (et 127.0.0.1 / :3001) pour Next en local — utiliser http, pas https.
# CORS_ALLOWED_ORIGINS=https://ton-user.github.io

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
