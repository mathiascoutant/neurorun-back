JWT_SECRET=remplace-par-une-chaine-longue-aleatoire
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

FRONTEND_URL=https://neurorun.fr
STRAVA_REDIRECT_URI=https://neurorun.fr/api/strava/callback
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_DB=runapp
# Défaut : IPv4 uniquement vers Mongo. Désactiver : MONGODB_FORCE_IPV4=0
#
# Avec network_mode: host (docker-compose) : lier uniquement sur localhost + port nginx.
LISTEN_HOST=127.0.0.1
PORT=9081
